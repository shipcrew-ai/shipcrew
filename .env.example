# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db
# For PostgreSQL: DATABASE_URL=postgresql://devteam:devteam_secret@localhost:5432/devteam

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Webhooks ────────────────────────────────────────────────────────────────
# Default webhook bearer token (can also be generated per-project via the API)
WEBHOOK_SECRET=change_me_to_a_secure_random_string

# ─── Sandbox ─────────────────────────────────────────────────────────────────
# Base path for Docker container workspace volumes (host path)
SANDBOX_BASE_PATH=/tmp/devteam-sandboxes
# Docker image used for project sandboxes
SANDBOX_IMAGE=node:20-alpine

# ─── Notifications (optional) ────────────────────────────────────────────────
# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DevTeam AI <noreply@devteam.ai>

# Slack
SLACK_WEBHOOK_URL=

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@devteam.ai
